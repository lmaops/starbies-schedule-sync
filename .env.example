# Domain (e.g. schedules.example.com)
DOMAIN=

# SQLite database path
DB_PATH=/data/sbuxsync.db

# Master Encryption Key — 64 hex chars (256-bit AES key)
# Generate with: openssl rand -hex 32
MEK=

# SMTP (leave blank to print PINs to app logs in dev mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

